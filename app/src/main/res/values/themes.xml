<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Settings and dialogs: forced dark, futuristic surface. -->
    <style name="Theme.LastLauncher" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="android:colorBackground">@color/deep_space</item>
        <item name="colorSurface">@color/deep_space</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <!-- Home screen: transparent over the live wallpaper, edge to edge. -->
    <style name="Theme.LastLauncher.Home">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
