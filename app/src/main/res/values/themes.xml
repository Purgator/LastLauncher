<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Settings and dialogs: forced dark, futuristic surface. -->
    <style name="Theme.LastLauncher" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="android:colorBackground">@color/deep_space</item>
        <item name="colorSurface">@color/deep_space</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <!-- Notification count bubble on suggestion icons. -->
    <style name="SuggestionBadge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">top|end</item>
        <item name="android:layout_marginTop">-2dp</item>
        <item name="android:layout_marginEnd">-2dp</item>
        <item name="android:background">@drawable/bg_badge</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">18dp</item>
        <item name="android:minHeight">18dp</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:textColor">@color/deep_space</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:visibility">gone</item>
    </style>

    <!-- Home screen: transparent over the live wallpaper, edge to edge. -->
    <style name="Theme.LastLauncher.Home">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
