<?xml version="1.0" encoding="utf-8"?>
<!-- Root settings: one entry per domain, each opening its own subscreen. -->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Preference
        android:key="screen_general"
        android:title="@string/cat_general"
        android:summary="@string/screen_general_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$GeneralFragment" />

    <Preference
        android:key="screen_clock_weather"
        android:title="@string/cat_clock_weather"
        android:summary="@string/screen_clock_weather_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$ClockWeatherFragment" />

    <Preference
        android:key="screen_suggestions"
        android:title="@string/cat_suggestions"
        android:summary="@string/screen_suggestions_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$SuggestionsFragment" />

    <Preference
        android:key="screen_gestures"
        android:title="@string/cat_gestures"
        android:summary="@string/screen_gestures_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$GesturesFragment" />

    <Preference
        android:key="screen_appearance"
        android:title="@string/cat_appearance"
        android:summary="@string/screen_appearance_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$AppearanceFragment" />

    <Preference
        android:key="screen_apps"
        android:title="@string/cat_apps"
        android:summary="@string/screen_apps_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$AppsFragment" />

    <Preference
        android:key="screen_notifications"
        android:title="@string/cat_notifications"
        android:summary="@string/screen_notifications_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$NotificationsFragment" />

    <Preference
        android:key="insights"
        android:title="@string/pref_insights"
        android:summary="@string/pref_insights_summary" />

    <Preference
        android:key="screen_updates"
        android:title="@string/cat_updates"
        android:summary="@string/screen_updates_summary"
        app:fragment="fr.arichard.lastlauncher.settings.SettingsActivity$UpdatesFragment" />
</PreferenceScreen>
