<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dim layer over the wallpaper; alpha driven by settings. -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0.25" />

    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <LinearLayout
            android:id="@+id/clockRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextClock
                android:id="@+id/clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-thin"
                android:format12Hour="h:mm"
                android:format24Hour="HH:mm"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                tools:text="14:32" />
        </LinearLayout>

        <TextClock
            android:id="@+id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="-4dp"
            android:fontFamily="sans-serif-light"
            android:format12Hour="EEEE d MMMM"
            android:format24Hour="EEEE d MMMM"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            tools:text="Friday 11 July" />

        <!-- Optional weather chip; tap opens the configured weather app. -->
        <TextView
            android:id="@+id/weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone"
            tools:text="☀ 24°"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/statusLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.02"
            android:singleLine="true"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="› 82%⚡  ·  wifi  ·  ⏰07:00  ·  ↑23"
            tools:visibility="visible" />

        <!-- Message ticker: one unread message at a time, fading between them. -->
        <LinearLayout
            android:id="@+id/ticker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tickerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="320dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="WhatsApp · Marie" />

            <TextView
                android:id="@+id/tickerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="320dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="On arrive dans 10 minutes !" />
        </LinearLayout>

        <TextView
            android:id="@+id/updatePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_glass_pill"
            android:paddingHorizontal="18dp"
            android:paddingVertical="9dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Update 1.1.0 ready — tap to install"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/starterPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_glass_pill"
            android:paddingHorizontal="18dp"
            android:paddingVertical="9dp"
            android:text="@string/starter_pill"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <FrameLayout
            android:id="@+id/middle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Predicted apps: big main button flanked by two runners-up. -->
            <LinearLayout
                android:id="@+id/suggestionsBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="26dp"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:clipChildren="false">

                <LinearLayout
                    android:id="@+id/suggestLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="22dp"
                    android:visibility="invisible">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_glass_circle"
                        android:clipChildren="false">
                        <ImageView
                            android:id="@+id/suggestLeftIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/suggestion_slot" />
                        <TextView
                            android:id="@+id/suggestLeftBadge"
                            style="@style/SuggestionBadge"
                            tools:text="2"
                            tools:visibility="visible" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/suggestLeftLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:maxWidth="76dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        tools:text="Maps" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/suggestMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:visibility="invisible">

                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:clipChildren="false">

                        <ImageView
                            android:id="@+id/mainGlow"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:src="@drawable/bg_glow_main"
                            android:importantForAccessibility="no" />

                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_glass_circle"
                            android:clipChildren="false">
                            <ImageView
                                android:id="@+id/suggestMainIcon"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/suggestion_slot" />
                            <TextView
                                android:id="@+id/suggestMainBadge"
                                style="@style/SuggestionBadge"
                                tools:text="5"
                                tools:visibility="visible" />
                        </FrameLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/suggestMainLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxWidth="110dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        tools:text="Spotify" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/suggestRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="22dp"
                    android:visibility="invisible">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_glass_circle"
                        android:clipChildren="false">
                        <ImageView
                            android:id="@+id/suggestRightIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/suggestion_slot" />
                        <TextView
                            android:id="@+id/suggestRightBadge"
                            style="@style/SuggestionBadge"
                            tools:text="1"
                            tools:visibility="visible" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/suggestRightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:maxWidth="76dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        tools:text="Chrome" />
                </LinearLayout>
            </LinearLayout>

            <!-- CLI-style gesture hints pinned to each edge, vertically centered. -->
            <TextView
                android:id="@+id/hintLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:fontFamily="monospace"
                android:maxWidth="150dp"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:importantForAccessibility="no"
                android:visibility="gone"
                tools:text="&gt; Quick settings"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/hintRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:fontFamily="monospace"
                android:maxWidth="150dp"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textAlignment="viewEnd"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:importantForAccessibility="no"
                android:visibility="gone"
                tools:text="Camera &lt;"
                tools:visibility="visible" />

            <!-- Search results / all apps. Fills the space above the search bar. -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_results_panel"
                android:paddingVertical="8dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:visibility="gone"
                tools:visibility="gone" />
        </FrameLayout>

        <!-- Command bar: assistant · type-to-launch · all apps. -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_glass_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp">

            <ImageButton
                android:id="@+id/modeBtn"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/mode_button"
                android:src="@drawable/ic_mode_smart"
                app:tint="@color/text_secondary" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/search_hint"
                android:imeOptions="actionGo|flagNoExtractUi"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="8dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/allAppsBtn"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/all_apps_button"
                android:src="@drawable/ic_apps"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Two independent, background-less wheel drawers pinned to each edge. Non-modal:
         the narrow band leaves the center and command bar usable, and both can be open. -->
    <!-- Follows the finger during a suggestions swipe; sparkles near completion. -->
    <ImageView
        android:id="@+id/swipeGlow"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="top|start"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <TextView
        android:id="@+id/swipeSparkle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:text="✦ ✧ ✦"
        android:textColor="@color/accent_cyan"
        android:textSize="16sp"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <!-- Ghost icon that flies back to its origin when a drag is dropped nowhere. -->
    <ImageView
        android:id="@+id/dragGhost"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|start"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <!-- New-app spotlight: a freshly installed app shines on one edge for a while.
         Side and vertical offset are applied at runtime. -->
    <FrameLayout
        android:id="@+id/newAppSpot"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_gravity="top|end"
        android:clipChildren="false"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/newAppGlow"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:src="@drawable/bg_glow_main"
            android:importantForAccessibility="no" />

        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_glass_circle">
            <ImageView
                android:id="@+id/newAppIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:id="@+id/newAppStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:text="✦"
            android:textSize="14sp"
            android:textColor="@color/accent_cyan"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Height is set to half the screen at runtime, vertically centered. -->
    <fr.arichard.lastlauncher.ui.WheelDrawer
        android:id="@+id/leftDrawer"
        android:layout_width="152dp"
        android:layout_height="360dp"
        android:layout_gravity="start|center_vertical"
        android:visibility="gone" />

    <fr.arichard.lastlauncher.ui.WheelDrawer
        android:id="@+id/rightDrawer"
        android:layout_width="152dp"
        android:layout_height="360dp"
        android:layout_gravity="end|center_vertical"
        android:visibility="gone" />
</FrameLayout>
